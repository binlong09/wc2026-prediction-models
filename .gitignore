# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Fetched raw data — reproducible via `cli.py fetch` (results.csv is ~3.6 MB)
data/raw/

# Generated report artifacts — regenerated by `report` / `scorelog`. The HTML and
# PNGs stay local; companion.json IS tracked (the companion app fetches it from
# the repo). Use `report/*` (not `report/`) so the negation below can re-include it.
report/*
!report/companion.json

# OS noise
.DS_Store

# The SQLite DB is a REBUILDABLE WORKING FILE — not committed. The durable,
# irreplaceable state lives as human-readable CSVs in data/state/ (committed);
# `cli.py rebuild` reconstructs the DB from those + external fetches.
data/backtest.db

# Real hand-entered market CSVs stay local; only the .example template is tracked
data/market/matchday_*.csv
!data/market/*.example.csv
