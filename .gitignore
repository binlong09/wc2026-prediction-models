.DS_Store

# NOTE: data/backtest.db IS tracked on purpose — it holds the resolved
# market_map the scheduler reads, and the snapshot-market workflow commits
# captured prices back to it. Remove from tracking with `git rm --cached
# data/backtest.db` if you'd rather persist snapshots elsewhere.

# Real hand-entered market CSVs stay local; only the .example template is tracked
data/market/matchday_*.csv
!data/market/*.example.csv
